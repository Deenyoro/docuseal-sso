# DocuSeal SSO deployment configuration.
# Copy to .env in this directory and edit:  cp .env.example .env

# Image built by the GitHub Actions workflow and pushed to GHCR.
DOCUSEAL_SSO_IMAGE=ghcr.io/deenyoro/docuseal-sso:latest

# Public hostname and host port.
HOST=localhost
DOCUSEAL_PORT=3000

# Set FORCE_SSL to your https host (e.g. docuseal.example.com) when behind TLS.
FORCE_SSL=

# Generate with: openssl rand -hex 64
SECRET_KEY_BASE=changeme-generate-with-openssl-rand-hex-64

# Postgres password (used by both the app and the postgres service).
POSTGRES_PASSWORD=postgres
